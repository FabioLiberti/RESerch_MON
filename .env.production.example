# FL Research Monitor — PRODUCTION env template (committed as reference)
#
# The real .env.production file lives ONLY on the VPS, at /opt/reserch_mon/.env.production,
# with permissions 600 and owner fabio:fabio. It is gitignored and must NEVER be committed.
#
# Copy this file, fill in real values, then scp it to the VPS or create it there directly.
# Paths are resolved inside the container (relative to /app, bind-mounted from ./data on the host).

# ----- Database (SQLite on the bind-mounted volume) -----
DATABASE_URL=sqlite+aiosqlite:///./data/db/research_monitor.db

# ----- Authentication (production secrets — see password manager) -----
JWT_SECRET_KEY=<from password manager>
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<from password manager — 12-20 chars>
ADMIN_EMAIL=fabioliberti.fl@gmail.com
API_SERVICE_KEY=<from password manager>

# ----- External research APIs (may be the same as dev or different) -----
NCBI_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
IEEE_API_KEY=
ELSEVIER_API_KEY=
ZOTERO_API_KEY=
ZOTERO_USER_ID=

# ----- Claude API -----
ANTHROPIC_API_KEY=

# ----- App settings -----
# APP_ENV=production activates the APScheduler (daily discovery at 06:00 UTC)
APP_ENV=production
LOG_LEVEL=INFO
# CORS: only the production subdomain is allowed as origin
CORS_ORIGINS=https://resmon.fabioliberti.com

# ----- Storage paths (mapped to ./data/ on the VPS host via bind-mount) -----
PDF_STORAGE_PATH=./data/pdfs
REGISTRY_PATH=./data/registry
REPORTS_PATH=./data/reports
