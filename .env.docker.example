# FL Research Monitor — Docker local stack env template
#
# Copy this file to `.env.docker` (gitignored) and fill in the real secrets.
# These variables are injected into the backend + frontend containers via
# docker-compose.yml `env_file`. They are SEPARATE from backend/.env
# (the native-dev file), so the two stacks can run in parallel without
# stepping on each other.
#
# Paths are resolved relative to /app inside the container, so ./data/...
# resolves to /app/data/..., which is bind-mounted from ./data-docker/.

# ----- Database (SQLite on the bind-mounted volume) -----
DATABASE_URL=sqlite+aiosqlite:///./data/db/research_monitor.db

# ----- Authentication -----
JWT_SECRET_KEY=CHANGE-ME-LOCAL-DOCKER
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@localhost
API_SERVICE_KEY=

# ----- External research APIs (copy from backend/.env if already set) -----
NCBI_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
IEEE_API_KEY=
ELSEVIER_API_KEY=
ZOTERO_API_KEY=
ZOTERO_USER_ID=

# ----- Claude API -----
ANTHROPIC_API_KEY=

# ----- App settings -----
APP_ENV=docker-local
LOG_LEVEL=INFO
# Caddy serves the stack on :8080, so the browser origin is http://localhost:8080
CORS_ORIGINS=http://localhost:8080

# ----- Storage paths (inside the container, mapped to ./data-docker/ on the host) -----
PDF_STORAGE_PATH=./data/pdfs
REGISTRY_PATH=./data/registry
REPORTS_PATH=./data/reports
